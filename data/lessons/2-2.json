{
  "id": "2-2",
  "title": "Прошедшее, будущее, приказы",
  "xp": 15,
  "theory": [
    {
      "title": "Прошедшее время",
      "body": "Та же логика, что и в настоящем времени — просто другое окончание, добавляется к инфинитиву целиком: тип 1 → добавь da. Тип 2 → добавь a.",
      "examples": [
        { "word": "e → eda", "ipa": "", "translation": "быть → был" },
        { "word": "ane → aneda", "ipa": "", "translation": "делать → делал" },
        { "word": "hūl → hūla", "ipa": "", "translation": "хотеть → хотел" }
      ]
    },
    {
      "title": "Будущее время",
      "body": "И снова то же самое, третье окончание: тип 1 → добавь do. Тип 2 → добавь o.",
      "examples": [
        { "word": "e → edo", "ipa": "", "translation": "быть → буду" },
        { "word": "ane → anedo", "ipa": "", "translation": "делать → буду делать" },
        { "word": "hūl → hūlo", "ipa": "", "translation": "хотеть → буду хотеть" }
      ]
    },
    {
      "title": "Повелительное наклонение (приказы)",
      "body": "Чтобы отдать приказ или попросить что-то сделать, тип слова уже не важен — просто ставь Se перед инфинитивом.",
      "examples": [
        { "word": "Se ane", "ipa": "", "translation": "делай!" },
        { "word": "Se e", "ipa": "", "translation": "будь!" }
      ]
    },
    {
      "title": "Все формы вместе",
      "body": "Для наглядности — как выглядит один и тот же глагол во всех формах, которые мы уже знаем.",
      "examples": [
        { "word": "hūl", "ipa": "инфинитив", "translation": "хотеть" },
        { "word": "hūle", "ipa": "наст.", "translation": "хочу/хочешь/хочет..." },
        { "word": "hūla", "ipa": "прош.", "translation": "хотел(а)" },
        { "word": "hūlo", "ipa": "буд.", "translation": "буду хотеть" },
        { "word": "Se hūl", "ipa": "повел.", "translation": "хоти! (редко используется по смыслу, но грамматически верно)" }
      ]
    }
  ],
  "exercises": [
