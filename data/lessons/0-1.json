{
  "id": "0-1",
  "title": "Буквы и звуки",
  "xp": 10,
  "theory": [
    {
      "title": "27 знакомых букв",
      "body": "В Arcon используется обычный латинский алфавит от a до z, плюс одна дополнительная буква — ū (u с чертой сверху). Большинство букв читаются почти так же, как в английском или в транскрипции IPA.",
      "examples": []
    },
    {
      "title": "Гласные",
      "body": "Пять привычных гласных плюс особенная ū, которая читается не как отдельный звук, а как сочетание «ю» — [ju].",
      "examples": [
        { "word": "a", "ipa": "[a]", "translation": "как в слове «papa»" },
        { "word": "e", "ipa": "[ɛ] (иногда [e])", "translation": "оба варианта верны" },
        { "word": "i", "ipa": "[i]", "translation": "" },
        { "word": "o", "ipa": "[o]", "translation": "" },
        { "word": "u", "ipa": "[u]", "translation": "" },
        { "word": "ū", "ipa": "[ju]", "translation": "особенная буква Arcon" }
      ]
    },
    {
      "title": "Согласные",
      "body": "Согласные читаются очень предсказуемо (b, d, f, g, l, m, n, p, r, s, t, v, z — как обычно) однако есть пару согласных о которых надо кое что знать:",
      "examples": [
        { "word": "c", "ipa": "[k]", "translation": "всегда как «к», не «с»" },
        { "word": "h", "ipa": "[x]", "translation": "как русское «х»" },
        { "word": "j", "ipa": "[ʒ]", "translation": "как русское «ж»" },
        { "word": "q", "ipa": "[kj]", "translation": "мягкое «кй»" },
        { "word": "w", "ipa": "[v]", "translation": "звучит как v, но встречается редко — в основном в заимствованных словах" },
        { "word": "x", "ipa": "[ks]", "translation": "как русское «кс»" },
        { "word": "y", "ipa": "[i]", "translation": "звучит как i" }
      ]
    }
  ],
  "exercises": [
    {
      "type": "choice",
      "prompt": "Какой звук у буквы h?",
      "ipaHint": null,
      "options": ["[h]", "[x]", "[g]", "[k]"],
      "answer": "[x]"
    },
    {
      "type": "choice",
      "prompt": "Какой звук у буквы c?",
      "ipaHint": null,
      "options": ["[s]", "[tʃ]", "[k]", "[ts]"],
      "answer": "[k]"
    },
    {
      "type": "choice",
      "prompt": "Какой звук у буквы j?",
      "ipaHint": null,
      "options": ["[dʒ]", "[j]", "[ʒ]", "[x]"],
      "answer": "[ʒ]"
    },
    {
      "type": "match",
      "pairs": [
        ["ū", "[ju]"],
        ["h", "[x]"],
        ["j", "[ʒ]"],
        ["q", "[kj]"]
      ]
    }
  ]
}
